<?xml version="1.0" encoding="utf-8" ?>
<Defs>
	<!-- HORNY TRIBAL RAIDS -->
	<IncidentDef>
		<defName>Luxandra_Inc_HornyTribalRaid</defName>
		<label>Horny tribe raid</label>
		<workerClass>LuxandraLust.IncidentWorker_HornyTribalRaid</workerClass>
		<category>ThreatBig</category>
		<baseChance>1.0</baseChance>
		<targetTags>
			<li>Map_PlayerHome</li>
		</targetTags>
		<pointsScaleable>true</pointsScaleable>
		<letterLabel>Horny Raid</letterLabel>
		<letterText>Attackers from {0} have arrived! Their gods demand your blood... and your buttholes, if possible! Their war cries were so unsettling and yet somehow made all your colonists feel horny, prepare for defense!</letterText>
		<letterDef>ThreatBig</letterDef>
	</IncidentDef>

	<!-- UGLY BASTARDS -->
	<IncidentDef MayRequire="archersaiter.rjw.unleashed.bastard">
		<defName>Luxandra_Inc_UnleashedBastardsRaid</defName>
		<label>Rapist raid</label>
		<workerClass>LuxandraLust.IncidentWorker_BastardRaid</workerClass>
		<category>ThreatBig</category>
		<baseChance>1.0</baseChance>
		<targetTags>
			<li>Map_PlayerHome</li>
		</targetTags>
		<pointsScaleable>true</pointsScaleable>
		<letterLabel>Rapist Raid</letterLabel>
		<letterText>Attackers from {0} have arrived! They have vile intentions... they're here to rape as many defenseless pawns as possible. Be ready...</letterText>
		<letterDef>ThreatBig</letterDef>
	</IncidentDef>
	
	<RaidStrategyDef>
		<defName>LL_RapeAndPillageAssault</defName>
		<workerClass>LuxandraLust.RaidStrategyWorker_RapeAssault</workerClass>
		<letterLabelEnemy>Raid (Vile Assault)</letterLabelEnemy>
		<arrivalTextEnemy>A group of raiders have arrived. They are attacking immediately, and they seem to have exceptionally vile intentions for any survivors...</arrivalTextEnemy>
		<selectionWeightPerPointsCurve>
			<points>
				<li>(400, 0.0)</li>
				<li>(1000, 1.2)</li>
			</points>
		</selectionWeightPerPointsCurve>
		<arriveModes>
			<li>EdgeWalkIn</li>
			<li>EdgeDrop</li>
		</arriveModes>
	</RaidStrategyDef>
  
	<DutyDef>
		<defName>LL_BastardAssaultDuty</defName>
		<thinkNode Class="ThinkNode_Priority">
			<subNodes>
				<!-- Rape enemies -->
				<li Class="rjw.JobGiver_RapeEnemy"/>

				<!-- Fight visible enemies natively -->
				<li Class="JobGiver_AIFightEnemies"/>
        
				<!-- Travel to the nearest hostile target across the map -->
				<li Class="JobGiver_AIGotoNearestHostile"/>
		
				<!-- Smash buildings/furniture far away (basically forces them to go to the base) -->
				<li Class="JobGiver_AITrashBuildingsDistant"/>

				<!-- Smash things right next to them inside the base -->
				<li Class="JobGiver_AITrashColonyClose"/>
			</subNodes>
		</thinkNode>
	</DutyDef>
  
	<!-- This hediff tanks the sex drive of the pawn, combined with
		rapist trait they'll go on a turbo rape frenzy-->
	<HediffDef>
		<defName>LL_RapistRage</defName>
		<label>Rapist frenzy</label>
		<description>A chemically induced frenzy causing a massive increase in carnal desires.</description>
		<hediffClass>HediffWithComps</hediffClass>
		<defaultLabelColor>(0.9, 0.2, 0.2)</defaultLabelColor>
		<scenarioCanAdd>false</scenarioCanAdd>
		<maxSeverity>1.0</maxSeverity>
		<comps>
			<li Class="HediffCompProperties_Disappears">
				<disappearsAfterTicks>15000</disappearsAfterTicks>
				<showRemainingTime>true</showRemainingTime>
			</li>
		</comps>
		<stages>
			<li>
				<statOffsets>
					<SexFrequency>50.0</SexFrequency>
					<Vulnerability>-10</Vulnerability>
				</statOffsets>
				<statFactors>
					<SexSatisfaction>0.2</SexSatisfaction>
				</statFactors>
			</li>
		</stages>
	</HediffDef>

</Defs>