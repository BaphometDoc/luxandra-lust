<?xml version="1.0" encoding="utf-8" ?>
<Defs>

	<IncidentDef>
		<defName>Luxandra_Inc_FertilityPulseSite</defName>
		<label>fertility pulse transmitter detected</label>
		<category>ThreatBig</category>
		<workerClass>LuxandraLust.IncidentWorker_FertilityPulseSite</workerClass>
		<targetTags>
			<li>Map_PlayerHome</li>
		</targetTags>
		<baseChance>0.3</baseChance>
		<minThreatPoints>150</minThreatPoints>
		<letterDef>NegativeEvent</letterDef>
		<minRefireDays>15</minRefireDays>
	</IncidentDef>

	<SitePartDef>
		<defName>Luxandra_FertilityPulseSitePart</defName>
		<label>fertility pulse transmitter</label>
		<description>A site containing a localized psychic transmitter emitting a frequency across the region.</description>
		<workerClass>SitePartWorker_ConditionCauser</workerClass>
		<conditionCauserDef>Luxandra_FertilityPulseTransmitter</conditionCauserDef>
		<tags>
			<li>ConditionCauser</li>
		</tags>
		<siteTexture>World/WorldObjects/Sites/GenericSite</siteTexture>
		<expandingIconTexture>World/WorldObjects/Expanding/Sites/Ambush</expandingIconTexture>
	</SitePartDef>

	<GenStepDef>
		<defName>Luxandra_FertilityPulseGenStep</defName>
		<order>450</order>
		<linkWithSite>Luxandra_FertilityPulseSitePart</linkWithSite>
		<genStep Class="GenStep_ConditionCauser"/>
	</GenStepDef>
	
	<ThingDef ParentName="BuildingBase">
		<defName>Luxandra_FertilityPulseTransmitter</defName>
		<label>Fertility pulse transmitter</label>
		<description>An ancient, humming mechanoid archetype device. It utilizes localized psychic frequencies to broadcast an intense reproductive overloading signal across the region.</description>
		<thingClass>Building</thingClass>
		<category>Building</category>
		<graphicData>
			<texPath>Things/Buildings/Luxandra_Transmitter</texPath>
			<graphicClass>Graphic_Single</graphicClass>
			<drawSize>(3.2, 3.2)</drawSize>
			<drawOffset>(0,0,-0.15)</drawOffset>
			<shaderType>Cutout</shaderType>
			<shadowData>
				<volume>(2.8, 1.0, 2.8)</volume>
			</shadowData>
		</graphicData>
		<altitudeLayer>Building</altitudeLayer>
		<selectable>true</selectable>
		<fillPercent>1.0</fillPercent>
		<size>(3,3)</size>
		<tickerType>Normal</tickerType>
		<rotatable>false</rotatable>
		<statBases>
			<MaxHitPoints>600</MaxHitPoints>
			<Flammability>0.0</Flammability>
			<MarketValue>1200</MarketValue>
		</statBases>
		<building>
			<claimable>false</claimable>
		</building>
		<comps>
			<li Class="CompProperties_CausesGameCondition">
				<conditionDef>Luxandra_LustfulFertilityPulse</conditionDef>
				<worldRange>35</worldRange>
			</li>
			<li Class="CompProperties_Glower">
				<glowRadius>6</glowRadius>
				<glowColor>(230, 50, 150, 0)</glowColor>
			</li>
		</comps>
		<killedLeavings>
			<Steel>50</Steel>
			<Plasteel>25</Plasteel>
			<ComponentSpacer>1</ComponentSpacer>
		</killedLeavings>
	</ThingDef>

</Defs>