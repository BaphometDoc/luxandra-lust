<?xml version="1.0" encoding="utf-8" ?>
	<!-- This is totally not nymphs. Nope. Totally not the nymphs from RJW 
	except they actually work (most of the time) -->
<Defs>
	<PawnKindDef>
		<defName>Luxandra_CarnalDeviantStriker</defName>
		<label>Carnal deviant</label>
		<race>Human</race>
		<combatPower>30</combatPower>
		<invNutrition>0</invNutrition>
		<itemQuality>Poor</itemQuality>
		<apparelMoney>0~0</apparelMoney>
		<weaponMoney>0~0</weaponMoney>
		<apparelAllowHeadgearChance>0</apparelAllowHeadgearChance>
		<apparelTags>
		</apparelTags>
		<techHediffsChance>0</techHediffsChance>
		<backstoryFiltersOverride>
			<li>
				<categories>
					<li>LL_RaiderDeviantCategory</li>
				</categories>
			</li>
		</backstoryFiltersOverride>
		<forcedTraits>
			<li>
				<def>Nymphomaniac</def>
			</li>
			<li>
				<def>Rapist</def>
			</li>
			<li>
				<def>Bisexual</def>
			</li>
			<!-- This used to have Zoophile too but apparently they kept 
			raping animals ignoring colonists ooops -->
		</forcedTraits>
		<initialWillRange>0~1</initialWillRange>
		<initialResistanceRange>1~3</initialResistanceRange>
		<defaultFactionType>LL_DeviantHordeFaction</defaultFactionType>
	</PawnKindDef>

	<BackstoryDef>
		<defName>LL_PrimalLustDeviant</defName>
		<title>Lustful Deviant</title>
		<titleShort>deviant</titleShort>
		<baseDesc>[PAWN_nameDef] is conscious and intellectually lucid, yet [PAWN_possessive] mind is gripped by an absolute, unyielding primal desire. While [PAWN_pronoun] can apparently converse normally, all interest in traditional work has completely evaporated due to their obsessive lust.</baseDesc>
		<slot>Adulthood</slot>
		<ignoreIllegalLabelCharacterConfigError>False</ignoreIllegalLabelCharacterConfigError>
		<spawnCategories>
			<li>LL_RaiderDeviantCategory</li>
		</spawnCategories>
		<skillGains>
			<Social>6</Social>
			<Melee>10</Melee>
			<Shooting>-10</Shooting>
			<Medicine>-4</Medicine>
			<Sex MayRequire="rjw.sexperience">15</Sex>
		</skillGains>
		<workDisables>
			<li>Animals</li>
			<li>Artistic</li>
			<li>PlantWork</li>
			<li>Mining</li>
			<li>ManualSkilled</li>
			<li>Cooking</li>
			<li>Firefighting</li>
			<li>Constructing</li>
		</workDisables>
		<requiredWorkTags>None</requiredWorkTags>
		<forcedTraits>
			<Nymphomaniac>0</Nymphomaniac>
			<Rapist>0</Rapist>
			<Bisexual>0</Bisexual>
		</forcedTraits>
		<bodyTypeGlobal>Thin</bodyTypeGlobal>
		<bodyTypeFemale>Thin</bodyTypeFemale>
		<bodyTypeMale>Thin</bodyTypeMale>
	</BackstoryDef>
  
	<BackstoryDef>
		<defName>LL_DeviantChildhoodFeral</defName>
		<title>Feral Deviant</title>
		<titleShort>Feral</titleShort>
		<baseDesc>[PAWN_nameDef] was raised in the untamed wilderness. Having never learned the constraints of societal laws, ethical frameworks, or basic morality, [PAWN_pronoun] grew up entirely guided by instinct and the immediate satisfaction of primal urges.</baseDesc>
		<slot>Childhood</slot>
		<spawnCategories>
			<li>LL_RaiderDeviantCategory</li>
		</spawnCategories>
		<skillGains/>
	</BackstoryDef>

	<FactionDef ParentName="FactionBase">
		<defName>LL_DeviantHordeFaction</defName>
		<label>deviant horde</label>
		<description>A wild swarm of deviant humans.</description>
		<pawnSingular>Carnal deviant</pawnSingular>
		<pawnsPlural>Carnal deviants</pawnsPlural>
		<hidden>true</hidden>
		<permanentEnemy>true</permanentEnemy>
		<autoFlee>false</autoFlee>
		<canSiege>false</canSiege>
		<canStageAttacks>true</canStageAttacks>
		<canGenerateQuestSites>false</canGenerateQuestSites>
		<factionIconPath>World/WorldObjects/Expanding/CannibalTribe</factionIconPath>
		<techLevel>Neolithic</techLevel>
		<backstoryFilters>
			<li>
				<categories>
					<li>LL_PrimalLustDeviant</li>
				</categories>
			</li>
		</backstoryFilters>
		<leaderTitle>Carnal Master</leaderTitle>
		<disallowedMemes>
			<li MayRequire="Ludeon.RimWorld.Ideology">Structure_Ideological</li>
			<li MayRequire="Ludeon.RimWorld.Ideology">Transhumanist</li>
			<li MayRequire="Ludeon.RimWorld.Ideology">Blindsight</li>
		</disallowedMemes>
		<disallowedPrecepts>
			<li MayRequire="Ludeon.RimWorld.Ideology">Nudity_Male_CoveringAnythingButGroinDisapproved</li>
			<li MayRequire="Ludeon.RimWorld.Ideology">Nudity_Female_CoveringAnythingButGroinDisapproved</li>
		</disallowedPrecepts>
		<requiredMemes>
			<li MayRequire="Ludeon.RimWorld.Ideology">Nudism</li>
			<li MayRequire="Ludeon.RimWorld.Ideology">Cannibal</li>
		</requiredMemes>
		<factionNameMaker>NamerFactionTribal</factionNameMaker>
		<settlementNameMaker>NamerSettlementTribal</settlementNameMaker>
		<requiredCountAtGameStart>1</requiredCountAtGameStart>
		<maxConfigurableAtWorldCreation>1</maxConfigurableAtWorldCreation>
		<configurationListOrderPriority>2000</configurationListOrderPriority>
		<displayInFactionSelection>false</displayInFactionSelection>
		<canSiege>false</canSiege>
		<raidCommonalityFromPointsCurve>
			<points>
				<li>(0, 0)</li>
			</points>
		</raidCommonalityFromPointsCurve>
	</FactionDef>

	<!-- DEBUFF APPLIED TO THE VICTIMS -->
	<HediffDef>
		<defName>Luxandra_DeviantStupor</defName>
		<label>lustful stupor</label>
		<description>A psychic fog clouding the mind. Stacks until the victim collapses into a total, helpless coma.</description>
		<hediffClass>HediffWithComps</hediffClass>
		<defaultLabelColor>(0.8, 0.4, 0.7)</defaultLabelColor>
		<maxSeverity>1.0</maxSeverity>
		<comps>
			<li Class="HediffCompProperties_SeverityPerDay">
				<severityPerDay>-0.5</severityPerDay>
			</li>
		</comps>
		<stages>
			<li>
				<label>hazed</label>
				<minSeverity>0.01</minSeverity>
				<capMods>
					<li>
						<capacity>Consciousness</capacity>
						<offset>-0.10</offset>
					</li>
				</capMods>
			</li>
			<li>
				<label>clouded</label>
				<minSeverity>0.40</minSeverity>
				<capMods>
					<li>
						<capacity>Consciousness</capacity>
						<offset>-0.30</offset>
					</li>
					<li>
						<capacity>Moving</capacity>
						<offset>-0.15</offset>
					</li>
				</capMods>
			</li>
			<li>
				<label>anesthetized stupor</label>
				<minSeverity>0.80</minSeverity>
				<capMods>
					<li>
						<capacity>Consciousness</capacity>
						<setMax>0.1</setMax>
					</li>
				</capMods>
			</li>
		</stages>
	</HediffDef>

	<!-- The "weapon" and all -->
	<ToolCapacityDef>
		<defName>Luxandra_StuporTouchCapacity</defName>
		<label>sedative touch</label>
	</ToolCapacityDef>

	<ManeuverDef>
		<defName>Luxandra_StuporTouchManeuver</defName>
		<requiredCapacity>Luxandra_StuporTouchCapacity</requiredCapacity>
		<verb>
			<verbClass>Verb_MeleeAttackDamage</verbClass>
		</verb>
		<logEntryDef>MeleeAttack</logEntryDef>
	</ManeuverDef>

	<HediffDef ParentName="ImplantHediffBase">
		<defName>Luxandra_EnthrallingTouch</defName>
		<label>sensual touch</label>
		<description>A poisonous touch evolved to weaken the preys, in order to use them while they're still alive.</description>
		<hediffClass>Hediff_Implant</hediffClass>
		<defaultLabelColor>(0.8, 0.4, 0.7)</defaultLabelColor>
		<isBad>false</isBad>
		<stages>
			<li>
				<statFactors>
					<!-- Reduces all outbound melee damage by 95% -->
					<MeleeDamageFactor>0.05</MeleeDamageFactor>
				</statFactors>
			</li>
		</stages>
		<comps>
			<li Class="HediffCompProperties_VerbGiver">
				<tools>
					<li>
						<label>flesh stroke</label>
						<capacities>
							<li>Blunt</li>
						</capacities>
						<power>2</power>
						<cooldownTime>1.5</cooldownTime>
						<extraMeleeDamages>
							<li>
								<def>Luxandra_StuporTouchDamage</def>
								<amount>1</amount>
								<chance>1.0</chance>
							</li>
						</extraMeleeDamages>
					</li>
				</tools>
			</li>
		</comps>
	</HediffDef>

	<DamageDef ParentName="BluntBase">
		<defName>Luxandra_StuporTouchDamage</defName>
		<label>sedative contact</label>
		<additionalHediffs>
			<li>
				<hediff>Luxandra_DeviantStupor</hediff>
				<severityPerDamageDealt>0.1</severityPerDamageDealt>
				<victimSeverityScalingByInvBodySize>true</victimSeverityScalingByInvBodySize>
			</li>
		</additionalHediffs>
		<applyAdditionalHediffsIfHuntingForFood>false</applyAdditionalHediffsIfHuntingForFood>
	</DamageDef>
</Defs>