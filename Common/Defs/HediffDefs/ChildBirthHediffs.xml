<?xml version="1.0" encoding="utf-8" ?>
<Defs>

	<!-- ========================================================================= -->
	<!--   PLEASURE BLESSING (GLOBAL COLONY MOOD BOOST)                            -->
	<!-- ========================================================================= -->
	<HediffDef>
		<defName>Luxandra_ColonyPleasureBlessing</defName>
		<label>Blessed Ecstasy</label>
		<description>Your actions have brought joy to Luxanna. Her divine favor manifests as a mental bliss across the entire colony.</description>
		<hediffClass>HediffWithComps</hediffClass>
		<defaultLabelColor>(0.85, 0.45, 0.85)</defaultLabelColor>
		<scenarioCanAdd>false</scenarioCanAdd>
		<maxSeverity>1.0</maxSeverity>
		<isBad>false</isBad>
		<comps>
			<li Class="HediffCompProperties_Disappears">
				<disappearsAfterTicks>180000</disappearsAfterTicks>
				<showRemainingTime>true</showRemainingTime>
			</li>
		</comps>
		<stages>
			<li>
				<becomeVisible>true</becomeVisible>
			</li>
		</stages>
	</HediffDef>

	<ThoughtDef>
		<defName>Luxandra_M_PleasureBlessing</defName>
		<workerClass>ThoughtWorker_Hediff</workerClass>
		<hediff>Luxandra_ColonyPleasureBlessing</hediff>
		<validWhileDespawned>true</validWhileDespawned>
		<stages>
			<li>
				<label>Luxandra's Ecstasy</label>
				<description>Our actions are in harmony with our nature, and Her divine approval echoes in our minds.</description>
				<baseMoodEffect>15</baseMoodEffect>
			</li>
		</stages>
	</ThoughtDef>


	<!-- ========================================================================= -->
	<!--    PARENTAL FERTILITY & FOCUSED MOOD BLESSING                             -->
	<!-- ========================================================================= -->
	<HediffDef>
		<defName>Luxandra_ParentalFertilityBlessing</defName>
		<label>Divine Proliferator</label>
		<description>Having birthed a child directly in accordance with her alignment, this parent has been touched with supreme fertility and wisdom.</description>
		<hediffClass>HediffWithComps</hediffClass>
		<defaultLabelColor>(0.9, 0.3, 0.7)</defaultLabelColor>
		<scenarioCanAdd>false</scenarioCanAdd>
		<maxSeverity>1.0</maxSeverity>
		<isBad>false</isBad>
		<comps>
			<li Class="HediffCompProperties_Disappears">
				<disappearsAfterTicks>180000</disappearsAfterTicks>
				<showRemainingTime>true</showRemainingTime>
			</li>
		</comps>
		<stages>
			<li>
				<capMods>
					<li>
						<capacity>Metabolism</capacity>
						<offset>0.10</offset>
					</li>
				</capMods>
				<statOffsets>
					<Fertility>1.50</Fertility>
					<GlobalLearningFactor>0.20</GlobalLearningFactor>
				</statOffsets>
			</li>
		</stages>
	</HediffDef>

	<ThoughtDef>
		<defName>Luxandra_M_ParentalBlessing</defName>
		<workerClass>ThoughtWorker_Hediff</workerClass>
		<hediff>Luxandra_ParentalFertilityBlessing</hediff>
		<validWhileDespawned>true</validWhileDespawned>
		<stages>
			<li>
				<label>Luxanna's Chosen Vessel</label>
				<description>I have brought life into this world exactly as she desired. The physical and mental pleasure of her acknowledgment is overwhelming.</description>
				<baseMoodEffect>30</baseMoodEffect>
			</li>
		</stages>
	</ThoughtDef>


	<!-- ========================================================================= -->
	<!--     BESTIAL DEGRADATION PUNISHMENT (CONSCIOUSNESS CAP & DEBUFF)           -->
	<!-- ========================================================================= -->
	<HediffDef>
		<defName>Luxandra_BestialDegradation</defName>
		<label>Bestial Degradation</label>
		<description>A horrific, uncivilized birth occurred within your colony boundaries. A thick fog wraps your minds, dragging human cognition down into basic animal limits.</description>
		<hediffClass>HediffWithComps</hediffClass>
		<defaultLabelColor>(0.4, 0.4, 0.4)</defaultLabelColor>
		<scenarioCanAdd>false</scenarioCanAdd>
		<maxSeverity>1.0</maxSeverity>
		<isBad>true</isBad>
		<comps>
			<li Class="HediffCompProperties_Disappears">
				<disappearsAfterTicks>180000</disappearsAfterTicks>
				<showRemainingTime>true</showRemainingTime>
			</li>
		</comps>
		<stages>
			<li>
				<capMods>
					<li>
						<capacity>Consciousness</capacity>
						<setMax>0.70</setMax>
					</li>
				</capMods>
			</li>
		</stages>
	</HediffDef>

	<ThoughtDef>
		<defName>Luxandra_M_BestialDegradation</defName>
		<workerClass>ThoughtWorker_Hediff</workerClass>
		<hediff>Luxandra_BestialDegradation</hediff>
		<validWhileDespawned>true</validWhileDespawned>
		<stages>
			<li>
				<label>Degraded to Beasts</label>
				<description>We committed an abominable act and defiled a beast. My brain feels muddy, stupid, and raw... like an animal left out in the mud.</description>
				<baseMoodEffect>-20</baseMoodEffect>
			</li>
		</stages>
	</ThoughtDef>
	
	<!-- ======================================================================= -->
	<!--                 COLD REVULSION (Incest Committed but Forbidden)         -->
	<!-- ======================================================================= -->
	<HediffDef>
		<defName>Luxandra_ColdRevulsion</defName>
		<label>cold revulsion</label>
		<description>A numbing, divine block settled over the mind after a sacred taboo was broken. Carnal desire has completely turned to ash, and the very thought of fleshly intimacy brings only a hollow, phantom ache.</description>
		<hediffClass>HediffWithComps</hediffClass>
		<defaultLabelColor>(0.4, 0.6, 0.9)</defaultLabelColor><!-- Icy Blue tint -->
		<isBad>true</isBad>
		<comps>
			<li Class="HediffCompProperties_Disappears">
				<disappearsAfterTicks>180000</disappearsAfterTicks>
				<showRemainingTime>true</showRemainingTime>
			</li>
		</comps>
		<stages>
			<li>
				<statOffsets>
					<SexFrequency>-0.5</SexFrequency>
					<SexSatisfaction>-0.5</SexSatisfaction>
				</statOffsets>
				<capMods>
					<li>
						<capacity>Consciousness</capacity>
						<offset>-0.05</offset>
					</li>
				</capMods>
			</li>
		</stages>
	</HediffDef>
	
	<ThoughtDef>
		<defName>Luxandra_M_GuiltOfTheProfane</defName>
		<workerClass>ThoughtWorker_Hediff</workerClass>
		<hediff>Luxandra_ColdRevulsion</hediff>
		<validWhileDespawned>true</validWhileDespawned>
		<stages>
			<li>
				<label>broken taboo</label>
				<description>What have we done? We crossed a sacred boundary we swore never to touch. The dirtiness of that forbidden act clings to my mind, and the hollow numbness following it is proof of our moral failure.</description>
				<baseMoodEffect>-2</baseMoodEffect>
			</li>
		</stages>
	</ThoughtDef>

	<!-- ======================================================================= -->
	<!--                WHIPPING GAZE (Incest Required but Omitted)              -->
	<!-- ======================================================================= -->
	<HediffDef>
		<defName>Luxandra_WhippingGaze</defName>
		<label>maddened pressure</label>
		<description>A furious, chemical psychic pressure driving hormones to absolute desperation. The body burns with an inescapable itch, demanding to expand the bloodline as soon as possible.</description>
		<hediffClass>HediffWithComps</hediffClass>
		<defaultLabelColor>(0.9, 0.2, 0.2)</defaultLabelColor>
		<isBad>true</isBad>
		<comps>
			<li Class="HediffCompProperties_Disappears">
				<disappearsAfterTicks>180000</disappearsAfterTicks>
				<showRemainingTime>true</showRemainingTime>
			</li>
		</comps>
		<stages>
			<li>
				<statOffsets>
					<SexFrequency>0.5</SexFrequency>
					<SexSatisfaction>-0.5</SexSatisfaction>
				</statOffsets>
				<capMods>
					<li>
						<capacity>Consciousness</capacity>
						<offset>-0.10</offset>
					</li>
				</capMods>
			</li>
		</stages>
	</HediffDef>
	
	<ThoughtDef>
		<defName>Luxandra_M_ExogamousBetrayal</defName>
		<workerClass>ThoughtWorker_Hediff</workerClass>
		<hediff>Luxandra_WhippingGaze</hediff>
		<validWhileDespawned>true</validWhileDespawned>
		<stages>
			<li>
				<label>unclean bloodline</label>
				<description>We were supposed to keep our lineage pure and insular, yet we chose the path of strangers. This agonizing, unquenchable pressure burning inside me is a direct mirror of our unfaithfulness.</description>
				<baseMoodEffect>-2</baseMoodEffect>
			</li>
		</stages>
	</ThoughtDef>
</Defs>