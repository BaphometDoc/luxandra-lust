<?xml version="1.0" encoding="utf-8"?>
<Defs>
	<!-- ============================== -->
	<!-- The faction -->
	<!-- ============================== -->
	<FactionDef MayRequire="Ludeon.RimWorld.Royalty" ParentName="FactionBase">
		<defName>Luxandra_PuritanCrusaders</defName>
		<label>Stainless order</label>
		<description>An ultra-orthodox, technologically supreme military order dedicated to the absolute eradication of psychological and genetic deviance. They possess advanced psionic manipulation and glitterworld weaponry, which they direct with ruthless efficiency against any settlement they deem to be tainted by heretical, hedonistic influences.</description>
		<pawnSingular>crusader</pawnSingular>
		<pawnsPlural>crusaders</pawnsPlural>
		<allowedCultures>
			<li>Astropolitan</li>
		</allowedCultures>
		<backstoryFilters>
			<li>
				<categories>
					<li>ImperialCommon</li>
				</categories>
			</li>
		</backstoryFilters>
		<structureMemeWeights>
			<Structure_OriginChristian MayRequire="Ludeon.RimWorld.Ideology">1</Structure_OriginChristian>
		</structureMemeWeights><colorSpectrum>
			<li>(0.98, 0.98, 0.98)</li>
		</colorSpectrum>
    
		<!-- Core Structural Requirements -->
		<techLevel>Ultra</techLevel>
		<hidden>false</hidden>
		<permanentEnemy>false</permanentEnemy>
		<naturalEnemy>true</naturalEnemy>
		<canSiege>true</canSiege>
		<canStageAttacks>true</canStageAttacks>
		<rescueesCanJoin>true</rescueesCanJoin>
		<autoFlee>true</autoFlee>
		<permanentEnemyToEveryoneExcept>
			<li>OutlanderCivil</li>
			<li>TribeCivil</li>
			<li>PlayerTribe</li>
			<li>PlayerColony</li>
			<li MayRequire="Ludeon.RimWorld.Ideology">Beggars</li>
			<li MayRequire="Ludeon.RimWorld.Anomaly">ResearchExpedition</li>
			<li MayRequire="Ludeon.RimWorld.Odyssey">GravshipCrew</li>
			<li MayRequire="Ludeon.RimWorld.Odyssey">TradersGuild</li>
		</permanentEnemyToEveryoneExcept>
		<arrivalLayerWhitelist>
			<li>Surface</li>
			<li MayRequire="Ludeon.RimWorld.Odyssey">Orbit</li>
		</arrivalLayerWhitelist>
		<baseTraderKinds>
			<li>Base_Empire_Standard</li>
		</baseTraderKinds>
		<caravanTraderKinds>
			<li>Empire_Caravan_TraderGeneral</li>
		</caravanTraderKinds>
		<leaderTitle>Divine Judge</leaderTitle>
		<fixedLeaderKinds>
			<li>Luxandra_Crusader_Leader</li>
		</fixedLeaderKinds>
		<leaderForceGenerateNewPawn>true</leaderForceGenerateNewPawn>
	
		<!-- Ideology setup -->
		<requiredMemes>
			<li MayRequire="Ludeon.RimWorld.Ideology">Guilty</li>
			<li MayRequire="Ludeon.RimWorld.Ideology">FleshPurity</li>
			<li MayRequire="Ludeon.RimWorld.Ideology">HumanPrimacy</li>
		</requiredMemes>
	
		<disallowedPrecepts>
			<li MayRequire="Ludeon.RimWorld.Ideology">Slavery_Disapproved</li>
			<li MayRequire="Ludeon.RimWorld.Ideology">Slavery_Horrible</li>
			<li MayRequire="Ludeon.RimWorld.Ideology">Slavery_Abhorrent</li>
			<li MayRequire="Ludeon.RimWorld.Ideology">Nudity_Male_Mandatory</li>
			<li MayRequire="Ludeon.RimWorld.Ideology">Nudity_Female_Mandatory</li>
			<li MayRequire="Ludeon.RimWorld.Ideology">Nudity_Female_CoveringAnythingButGroinDisapproved</li>
			<li MayRequire="Ludeon.RimWorld.Ideology">Lovin_FreeApproved</li>
			<li MayRequire="Ludeon.RimWorld.Ideology">Lovin_Free</li>
      
			<li MayRequire="rjw.sexperience.ideology">Bestiality_Acceptable</li>
			<li MayRequire="rjw.sexperience.ideology">Rape_Acceptable</li>
			<li MayRequire="rjw.sexperience.ideology">Incestuos_Free</li>
			<li MayRequire="rjw.sexperience.ideology">Incestuos_Disapproved_CloseOnly</li>
			<li MayRequire="rjw.sexperience.ideology">Incestuos_IncestOnly</li>
			<li MayRequire="rjw.sexperience.ideology">Sex_Free</li>
			<li MayRequire="rjw.sexperience.ideology">Sex_AnalOnly</li>
			<li MayRequire="rjw.sexperience.ideology">Sex_OralOnly</li>
			<li MayRequire="rjw.sexperience.ideology">Sex_Promiscuous</li>
			<li MayRequire="rjw.sexperience.ideology">Virgin_UselessF</li>
			<li MayRequire="rjw.sexperience.ideology">Virgin_UselessM</li>
			<li MayRequire="rjw.sexperience.ideology">Virgin_ShamefulF</li>
			<li MayRequire="rjw.sexperience.ideology">Virgin_ShamefulM</li>
	  
			<li MayRequire="calamabanana.rjw.brothelcolony">CB_Prostitution_Accepted</li>
			<li MayRequire="calamabanana.rjw.brothelcolony">CB_Prostitution_Essential</li>
			<li MayRequire="calamabanana.rjw.brothelcolony">CB_Prostitution_Sacred</li>
		</disallowedPrecepts>
    
		<!-- World Customization -->
		<requiredCountAtGameStart>1</requiredCountAtGameStart>
		<maxConfigurableAtWorldCreation>1</maxConfigurableAtWorldCreation>
		<canMakeRandomly>false</canMakeRandomly>
		<listOrderPriority Inherit="False">71</listOrderPriority>
		<settlementGenerationWeight>0.15</settlementGenerationWeight>
		<settlementTexturePath>World/WorldObjects/DefaultSettlement</settlementTexturePath>
    
		<!-- Aesthetics matching the Empire style -->
		<factionIconPath>World/WorldObjects/Expanding/Empire</factionIconPath>
		<factionNameMaker>Luxandra_Crusader_FactionNameMaker</factionNameMaker>
		<settlementNameMaker>Luxandra_Crusader_SettlementNameMaker</settlementNameMaker>
		<melaninRange>0~0.7</melaninRange>
		<allowedArrivalTemperatureRange>-50~60</allowedArrivalTemperatureRange>
		<colorSpectrum Inherit="False">
			<li>(0.95, 0.95, 0.95)</li>
			<li>(0.85, 0.85, 0.9)</li>
		</colorSpectrum>
    
		<apparelStuffFilter>
			<thingDefs>
				<li>Synthread</li>
				<li>Hyperweave</li>
				<li>Plasteel</li>
				<li>Steel</li>
			</thingDefs>
		</apparelStuffFilter>
    
		<xenotypeSet Inherit="False">
			<xenotypeChances>
				<Baseliner>1.0</Baseliner>
			</xenotypeChances>
		</xenotypeSet>
    
		<raidCommonalityFromPointsCurve>
			<points>
				<li>(0, 1)</li>
			</points>
		</raidCommonalityFromPointsCurve>
		<maxPawnCostPerTotalPointsCurve>
			<points>
				<li>(750, 100)</li>
				<li>(20000, 1250)</li>
				<li>(60000, 5000)</li>
				<li>(100000, 10000)</li>
				<li>(150000, 20000)</li>
			</points>
		</maxPawnCostPerTotalPointsCurve>
    
		<disallowedRaidStrategies>
			<li>Luxandra_DeviantHordeAssault</li>
			<li>Luxandra_RapeAndPillageAssault</li>
		</disallowedRaidStrategies>
  
		<pawnGroupMakers>
			<!-- 1. COMBAT RAID COMPOSITION -->
			<li>
				<kindDef>Combat</kindDef>
				<options>
					<Luxandra_Crusader_WhiteCape>10</Luxandra_Crusader_WhiteCape>
					<Luxandra_Crusader_Inquisitor MayRequire="Ludeon.RimWorld.Anomaly">6</Luxandra_Crusader_Inquisitor>
					<Luxandra_Crusader_Guard>4</Luxandra_Crusader_Guard>
					<Luxandra_Crusader_Seer>2</Luxandra_Crusader_Seer>
					<Luxandra_Crusader_Leader>1</Luxandra_Crusader_Leader>
				</options>
			</li>
			
			<li>
				<kindDef>Combat</kindDef>
				<disallowedStrategies>
					<li>Siege</li>
				</disallowedStrategies>
				<options>
					<Luxandra_Crusader_WhiteCape>8</Luxandra_Crusader_WhiteCape>
					<Luxandra_Crusader_Conscript>6</Luxandra_Crusader_Conscript>
					<Luxandra_Crusader_Cleanser>10</Luxandra_Crusader_Cleanser>
					<Luxandra_Crusader_Inquisitor MayRequire="Ludeon.RimWorld.Anomaly">5</Luxandra_Crusader_Inquisitor>
				</options>
			</li>

			<!-- 2. PEACEFUL TRADER CARAVAN COMPOSITION -->
			<li>
				<kindDef>Trader</kindDef>
				<traders>
					<Luxandra_Crusader_Seer>1</Luxandra_Crusader_Seer>
				</traders>
				<carriers>
					<Muffalo>1</Muffalo>
				</carriers>
				<guards>
					<Luxandra_Crusader_WhiteCape>6</Luxandra_Crusader_WhiteCape>
					<Luxandra_Crusader_Guard>2</Luxandra_Crusader_Guard>
				</guards>
			</li>

			<!-- 3. PERMANENT BASE/SETTLEMENT COMPOSITION -->
			<li>
				<kindDef>Settlement</kindDef>
				<options>
					<Luxandra_Crusader_WhiteCape>12</Luxandra_Crusader_WhiteCape>
					<Luxandra_Crusader_Inquisitor MayRequire="Ludeon.RimWorld.Anomaly">6</Luxandra_Crusader_Inquisitor>
					<Luxandra_Crusader_Guard>6</Luxandra_Crusader_Guard>
					<Luxandra_Crusader_Seer>3</Luxandra_Crusader_Seer>
					<Luxandra_Crusader_Leader>1</Luxandra_Crusader_Leader>
				</options>
			</li>
		</pawnGroupMakers>
		<basicMemberKind>Luxandra_Crusader_Conscript</basicMemberKind>
	</FactionDef>
  
	<!-- ============================== -->
	<!-- Pawndefs -->
	<!-- ============================== -->
	<PawnKindDef Name="Luxandra_PuritanCrusader_Base" Abstract="True">
		<race>Human</race>
		<combatPower>60</combatPower>
		<chronologicalAgeRange>35~45</chronologicalAgeRange>
		<minGenerationAge>35</minGenerationAge>
		<maxGenerationAge>45</maxGenerationAge>
		<initialWillRange>6~8</initialWillRange>
		<initialResistanceRange>40~45</initialResistanceRange>
		<backstoryFiltersOverride MayRequire="Ludeon.RimWorld.Royalty">
			<li>
				<categories>
					<li>ImperialCommon</li>
					<li>ImperialFighter</li>
					<li>ImperialRoyal</li>
				</categories>
			</li>
		</backstoryFiltersOverride>
		<forcedTraits>
			<li>
				<def>Psychopath</def>
			</li>
		</forcedTraits>
    
		<!-- Must be capable of violence -->
		<requiredWorkTags>
			<li>Violent</li>
		</requiredWorkTags>
    
		<!-- Flesh Purists: Absolutely zero bionics or tech-hediffs -->
		<techHediffsChance>0</techHediffsChance>
		<techHediffsMoney>0</techHediffsMoney>
		<techHediffsTags>
			<li>None</li>
		</techHediffsTags>
	</PawnKindDef>
	
	<!-- CONSCRIPTS (tactically useless cowards) -->
	<PawnKindDef ParentName="Luxandra_PuritanCrusader_Base">
		<defName>Luxandra_Crusader_Conscript</defName>
		<label>reluctant conscript</label>
		<combatPower>35</combatPower>
		<chronologicalAgeRange>20~35</chronologicalAgeRange>
		<minGenerationAge>20</minGenerationAge>
		<maxGenerationAge>35</maxGenerationAge>

		<initialWillRange>1~2</initialWillRange>
		<initialResistanceRange>2~5</initialResistanceRange>

		<forcedTraits>
			<li>
				<def>Wimp</def>
			</li>
			<li>
				<def>Greedy</def>
			</li>
		</forcedTraits>

		<skills>
			<li>
				<skill>Shooting</skill>
				<range>4~7</range>
			</li>
			<li>
				<skill>Melee</skill>
				<range>0~2</range>
			</li>
		</skills>

		<!-- High apparel budget for pompous, non-armor noble clothing -->
		<apparelMoney>4000~8000</apparelMoney>
		<apparelTags>
			<li>Royal</li>
			<li>RoyalTier1</li>
			<li>RoyalTier2</li>
			<li>RoyalTier3</li>
			<li>RoyalTier4</li>
			<li>RoyalTier5</li>
			<li>Cape</li>
		</apparelTags>
		<apparelDisallowTags>
			<li>ArmorPower</li>
			<li>IndustrialMilitaryAdvanced</li>
		</apparelDisallowTags>
		<apparelAllowHeadgearChance>0.5</apparelAllowHeadgearChance>

		<weaponMoney>1500~2500</weaponMoney>
		<weaponTags>
			<li>SniperRifle</li>
			<li>BoltActionRifle</li>
		</weaponTags>
	</PawnKindDef>

	<!-- GUARDS (The Regular Footsoldiers) -->
	<PawnKindDef ParentName="Luxandra_PuritanCrusader_Base">
		<defName>Luxandra_Crusader_Guard</defName>
		<label>puritan guard</label>
		<combatPower>150</combatPower>
    
		<backstoryFiltersOverride MayRequire="Ludeon.RimWorld.Royalty">
			<li>
				<categories>
					<li>ImperialFighter</li>
				</categories>
			</li>
		</backstoryFiltersOverride>

		<apparelMoney>7000~10000</apparelMoney>
		<weaponMoney>2000~3500</weaponMoney>

		<apparelTags>
			<li>ArmorPower</li>
			<li>SpacerMilitary</li>
			<li>ImperialHeavy</li>
		</apparelTags>
		<apparelAllowHeadgearChance>1.0</apparelAllowHeadgearChance>

		<weaponTags>
			<li>SpacerGun</li>
			<li>IndustrialGunAdvanced</li>
		</weaponTags>

		<isFighter>true</isFighter>
		<chemicalAddictionChance>0.0</chemicalAddictionChance>
	</PawnKindDef>

	<!-- WHITE CAPES (The Zealot Footsoldiers) -->
	<PawnKindDef ParentName="Luxandra_PuritanCrusader_Base">
		<defName>Luxandra_Crusader_WhiteCape</defName>
		<label>white cape zealot</label>
		<combatPower>70</combatPower>

		<apparelMoney>600~1200</apparelMoney>
		<apparelTags>
			<li>NeolithicPreacher</li>
			<li>Royal</li>
			<li>RoyalTier1</li>
		</apparelTags>
		<apparelRequired>
			<li>Apparel_Cape</li>
		</apparelRequired>
		<apparelAllowHeadgearChance>1.0</apparelAllowHeadgearChance>

		<weaponMoney>250~400</weaponMoney>
		<weaponTags>
			<li>Revolver</li>
		</weaponTags>
		<isFighter>true</isFighter>
	</PawnKindDef>

	<!-- INQUISITOR (The Cleansing Flame) -->
	<PawnKindDef ParentName="Luxandra_PuritanCrusader_Base" MayRequire="Ludeon.RimWorld.Anomaly">
		<defName>Luxandra_Crusader_Inquisitor</defName>
		<label>puritan inquisitor</label>
		<combatPower>140</combatPower>

		<apparelMoney>1500~3000</apparelMoney>
		<apparelTags>
			<li>RoyalTier2</li>
			<li>Cape</li>
		</apparelTags>
		<apparelRequired>
			<li>Apparel_Cape</li>
		</apparelRequired>
		<apparelColor>(115, 30, 30)</apparelColor>
		<apparelAllowHeadgearChance>1.0</apparelAllowHeadgearChance>
		
		<fixedInventory>
			<li>
				<thingDef>Gun_HellcatRifle</thingDef>
			</li>
		</fixedInventory>
		<!-- Forced to spawn with the Anomaly Hellcat Rifle -->
		<weaponMoney>600~2500</weaponMoney>
		<weaponTags>
			<li>AnomalyWeaponAdvanced</li>
		</weaponTags>
		<isFighter>true</isFighter>
	</PawnKindDef>
	
	<!-- CLEANSER (The Much More Cleansing Flame) -->
	<PawnKindDef ParentName="Luxandra_PuritanCrusader_Base">
		<defName>Luxandra_Crusader_Cleanser</defName>
		<label>puritan cleanser</label>
		<combatPower>85</combatPower>

		<forcedTraits>
			<li>
				<def>Pyromaniac</def>
			</li>
		</forcedTraits>

		<apparelMoney>3000~6000</apparelMoney>
		<apparelTags>
			<li>RoyalTier2</li>
			<li>Cape</li>
		</apparelTags>
		<apparelRequired>
			<li>Apparel_Cape</li>
		</apparelRequired>
		<apparelDisallowTags>
			<li>ArmorPower</li>
		</apparelDisallowTags>
		<apparelAllowHeadgearChance>1.0</apparelAllowHeadgearChance>

		<weaponMoney>350~1500</weaponMoney>
		<weaponTags>
			<li>GrenadeIncendiary</li>
			<li>GrenadeDestructive</li>
			<li>GrenadeFlame</li>
		</weaponTags>

		<isFighter>true</isFighter>
	</PawnKindDef>
	
	<!-- SEER (The Psychic Enforcer) -->
	<PawnKindDef ParentName="Luxandra_PuritanCrusader_Base">
		<defName>Luxandra_Crusader_Seer</defName>
		<label>puritan seer</label>
		<combatPower>160</combatPower>
		<chronologicalAgeRange>40~60</chronologicalAgeRange>
		<minGenerationAge>40</minGenerationAge>
		<maxGenerationAge>60</maxGenerationAge>

		<backstoryFiltersOverride MayRequire="Ludeon.RimWorld.Royalty">
			<li>
				<categories>
					<li>ImperialRoyal</li>
				</categories>
			</li>
		</backstoryFiltersOverride>

		<apparelMoney>4000~8000</apparelMoney>
		<apparelTags>
			<li>RoyalTier3</li>
			<li>RoyalTier4</li>
		</apparelTags>

		<apparelRequired>
			<li>Apparel_PsyfocusVest</li>
			<li>Apparel_PsyfocusRobe</li>
			<li>Apparel_EltexSkullcap</li>
		</apparelRequired>
		<apparelAllowHeadgearChance>1.0</apparelAllowHeadgearChance>

		<weaponMoney>1500~3000</weaponMoney>
		<weaponTags>
			<li>SpacerGun</li>
		</weaponTags>
		<isFighter>true</isFighter>
		
		<modExtensions>
			<li MayRequire="VanillaExpanded.VPsycastsE" Class="VanillaPsycastsExpanded.PawnKindAbilityExtension_Psycasts">
				<implantDef>VPE_PsycastAbilityImplant</implantDef>
				<initialLevel>1</initialLevel>
				<statUpgradePoints>1~7</statUpgradePoints>
				<unlockedPaths>
					<VPE_Staticlord>1~4|2~12</VPE_Staticlord>
				</unlockedPaths>
			</li>
		</modExtensions>
	</PawnKindDef>

	<!-- PURIST (The High Arbiter Leader) -->
	<PawnKindDef ParentName="Luxandra_PuritanCrusader_Base">
		<defName>Luxandra_Crusader_Leader</defName>
		<label>high purist</label>
		<combatPower>250</combatPower>
		<chronologicalAgeRange>50~60</chronologicalAgeRange>
		<minGenerationAge>50</minGenerationAge>
		<maxGenerationAge>60</maxGenerationAge>

		<backstoryFiltersOverride MayRequire="Ludeon.RimWorld.Royalty">
			<li>
				<categories>
					<li>ImperialRoyal</li>
					<li>ImperialFighter</li>
				</categories>
			</li>
		</backstoryFiltersOverride>

		<apparelMoney>9000~15000</apparelMoney>
		<apparelTags>
			<li>ArmorPower</li>
			<li>SpacerMilitary</li>
			<li>RoyalTier5</li>
		</apparelTags>
        
		<apparelRequired>
			<li>Apparel_Cape</li>
			<li>Apparel_Coronet</li>
		</apparelRequired>
		<apparelAllowHeadgearChance>1.0</apparelAllowHeadgearChance>

		<weaponMoney>3000~9000</weaponMoney>
		<weaponTags>
			<li>SpacerGun</li>
			<li>SpacerGunAdvanced</li>
		</weaponTags>
        
		<modExtensions>
			<li MayRequire="VanillaExpanded.VPsycastsE" Class="VanillaPsycastsExpanded.PawnKindAbilityExtension_Psycasts">
				<implantDef>VPE_PsycastAbilityImplant</implantDef>
				<initialLevel>1</initialLevel>
				<statUpgradePoints>2~10</statUpgradePoints>
				<unlockedPaths>
					<VPE_Staticlord>1~4|2~12</VPE_Staticlord>
					<VPE_Frostshaper>1~4|2~12</VPE_Frostshaper>
				</unlockedPaths>
			</li>
		</modExtensions>
		
		<isFighter>true</isFighter>
		<factionLeader>true</factionLeader>
	</PawnKindDef>

	<!-- ============================== -->
	<!-- Names -->
	<!-- ============================== -->
	
	<RulePackDef>
		<defName>Luxandra_Crusader_FactionNameMaker</defName>
		<include><li>GlobalUtility</li></include>
		<rulePack>
			<rulesStrings>
				<li>r_name->The [factionAdj] [factionNoun]</li>
				<li>r_name->[factionNoun] of the [sacredNoun]</li>
        
				<li>factionAdj->Holy</li>
				<li>factionAdj->Righteous</li>
				<li>factionAdj->Iron</li>
				<li>factionAdj->Sovereign</li>
				<li>factionNoun->Order</li>
				<li>factionNoun->Crusade</li>
				<li>factionNoun->Chapter</li>
				<li>factionNoun->Inquisition</li>
				<li>sacredNoun->Sword</li>
				<li>sacredNoun->Light</li>
				<li>sacredNoun->Chalice</li>
				<li>sacredNoun->Oath</li>
			</rulesStrings>
		</rulePack>
	</RulePackDef>

	<RulePackDef>
		<defName>Luxandra_Crusader_SettlementNameMaker</defName>
		<include><li>GlobalUtility</li></include>
		<rulePack>
			<rulesStrings>
				<li>r_name->[prefix][suffix]</li>
				<li>r_name->[structure] of [holyWord]</li>
        
				<li>prefix->Sion</li>
				<li>prefix->Val</li>
				<li>prefix->Iron</li>
				<li>prefix->Stal</li>
				<li>prefix->Gold</li>
				<li>suffix->guard</li>
				<li>suffix->fast</li>
				<li>suffix->spire</li>
				<li>suffix->hold</li>
				<li>structure->Bastion</li>
				<li>structure->Citadel</li>
				<li>structure->Sanctuary</li>
				<li>holyWord->Light</li>
				<li>holyWord->Judgment</li>
				<li>holyWord->The Pious</li>
			</rulesStrings>
		</rulePack>
	</RulePackDef>
</Defs>