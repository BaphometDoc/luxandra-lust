				<Luxandra_Amazoness>1.0</Luxandra_Amazoness>
			</xenotypeChances>
		</xenotypeSet>
    
		<raidCommonalityFromPointsCurve>
			<points>
				<li>(0, 1)</li>
			</points>
		</raidCommonalityFromPointsCurve>
		<maxPawnCostPerTotalPointsCurve>
			<points>
				<li>(750, 100)</li>
				<li>(20000, 1250)</li>
				<li>(60000, 5000)</li>
				<li>(100000, 10000)</li>
				<li>(150000, 20000)</li>
			</points>
		</maxPawnCostPerTotalPointsCurve>
    
		<pawnGroupMakers>
			<!-- 1. THE BLOOD HUNT (Standard Balanced Assault) -->
			<li>
				<kindDef>Combat</kindDef>
				<commonality>100</commonality>
				<options>
					<Luxandra_Amazon_Brawler>10</Luxandra_Amazon_Brawler>
					<Luxandra_Amazon_Hunter>7</Luxandra_Amazon_Hunter>
					<Luxandra_Amazon_PackMaster>3</Luxandra_Amazon_PackMaster>
					<Cobra>5</Cobra>
				</options>
			</li>

			<!-- 2. THE SQUALL SQUAD (Fast, Ranged Harassment / Early Game) -->
			<li>
				<kindDef>Combat</kindDef>
				<commonality>50</commonality>
				<options>
					<Luxandra_Amazon_Fledgling>3</Luxandra_Amazon_Fledgling>
					<Luxandra_Amazon_Hunter>10</Luxandra_Amazon_Hunter>
					<Luxandra_Amazon_Brawler>3</Luxandra_Amazon_Brawler>
				</options>
			</li>

			<!-- 3. THE SIREN'S CURSE (Specialized Psychic Infiltration) -->
			<li>
				<kindDef>Combat</kindDef>
				<commonality>30</commonality>
				<options>
					<Luxandra_Amazon_Brawler>8</Luxandra_Amazon_Brawler>
					<Luxandra_Amazon_Siren>3</Luxandra_Amazon_Siren>
					<Luxandra_Amazon_Hunter>4</Luxandra_Amazon_Hunter>
				</options>
			</li>

			<!-- 4. THE BLOOD-MOTHER'S WRATH (Elite Endgame Boss Raid) -->
			<li>
				<kindDef>Combat</kindDef>
				<commonality>20</commonality>
				<options>
					<Luxandra_Amazon_BloodMother>1</Luxandra_Amazon_BloodMother>
					<Luxandra_Amazon_Brawler>12</Luxandra_Amazon_Brawler>
					<Luxandra_Amazon_Siren>1</Luxandra_Amazon_Siren>
					<Luxandra_Amazon_Hunter>6</Luxandra_Amazon_Hunter>
				</options>
			</li>

		</pawnGroupMakers>
		<basicMemberKind>Luxandra_Amazon_Fledgling</basicMemberKind>
	</FactionDef>
	
	<!-- ============================== -->
	<!-- Xenotype -->
	<!-- ============================== -->
	<XenotypeDef>
		<defName>Luxandra_Amazoness</defName>
		<label>amazoness</label>
		<description>These women evolved for raw predatory efficiency and overwhelming physiological dominance. They possess extreme metabolic speeds, rapid cellular regeneration, and a hyper-acute nervous system. Because their skin continuously secretes a protective, pheromone-laced lipid barrier, they actively loathe the restriction of clothing, relying instead on blinding speed and raw violence to close the distance on their targets.</description>
		<iconPath>UI/Icons/Xenotypes/Amazoness</iconPath>
		<combatPowerFactor>1.2</combatPowerFactor>
		<genes>
			<li>ArchiteMetabolism</li>
			<li>XenogermReimplanter</li>
			<li>DiseaseFree</li>
			<li>PerfectImmunity</li>
			<li>RobustDigestion</li>
			<li>Superclotting</li>
			<li>NakedSpeed</li>
			<li>MinTemp_LargeDecrease</li>
			<li>MaxTemp_LargeIncrease</li>
			<li>FireResistant</li>
			<li>Aggression_HyperAggressive</li>
			<li>Robust</li>
			<li>Beauty_Beautiful</li>
			<li>Body_Standard</li>
			<li>DarkVision</li>
			<li>Unstoppable</li>
			<li>AptitudeTerrible_Construction</li>
			<li>AptitudeTerrible_Mining</li>
			<li>AptitudeTerrible_Cooking</li>
			<li>AptitudeTerrible_Artistic</li>

			<!-- Alpha Genes -->
			<li MayRequire="sarg.alphagenes">AG_DangerousRaidPresence</li>
			<li MayRequire="sarg.alphagenes">AG_EfficientMandibles</li>
			<li MayRequire="sarg.alphagenes">AG_TableResistance</li>
			<li MayRequire="sarg.alphagenes">AG_ArmourMinor</li>
			<li MayRequire="sarg.alphagenes">AG_FertilityLight</li>

			<!-- RJW / Sexperience Genes -->
			<li MayRequire="rjw.menstruation">Menstruation_DoubleEggLifetime</li>
			<li MayRequire="rjw.menstruation">Menstruation_NoBleeding</li>

			<!-- RJW Genes -->
			<li MayRequire="Vegapnk.rjw.genes">rjw_genes_size_blinded</li>
			<li MayRequire="Vegapnk.rjw.genes">rjw_genes_female_only</li>
			<li MayRequire="Vegapnk.rjw.genes">rjw_genes_big_breasts</li>
			<li MayRequire="Vegapnk.rjw.genes">rjw_genes_basic_rut</li>
			<li MayRequire="Vegapnk.rjw.genes">rjw_genes_elasticity</li>
			<li MayRequire="Vegapnk.rjw.genes">rjw_genes_unbreakable</li>
			<li MayRequire="Vegapnk.rjw.genes">rjw_genes_aphrodisiac_pheromones</li>
			<li MayRequire="Vegapnk.rjw.genes">rjw_genes_hormonal_saliva</li>
		</genes>
	</XenotypeDef>
  
