<?xml version="1.0" encoding="utf-8"?>
<Defs>
	<!-- ============================== -->
	<!-- The faction -->
	<!-- ============================== -->
	<FactionDef ParentName="FactionBase">
		<defName>Luxandra_AmazonTribe</defName>
		<label>feral amazon enclave</label>
		<description>A highly aggressive, hidden collective of genetically altered hunters. Driven by an all-consuming predatory instinct, they view other settlements purely as hunting grounds. Despite their absolute refusal to wear clothing, they wield terrifying, stolen spacer-grade weaponry stripped from the corpses of their prey.</description>
		<pawnSingular>amazoness</pawnSingular>
		<pawnsPlural>amazonesses</pawnsPlural>
		<allowedCultures>
			<li>Rustican</li>
		</allowedCultures>
		<backstoryFilters>
			<li>
				<categories>
					<li>Tribal</li>
				</categories>
			</li>
		</backstoryFilters>
		<colorSpectrum>
			<li>(0.15, 0.65, 0.15)</li>
			<li>(0.3, 0.5, 0.2)</li>
		</colorSpectrum>
    
		<!-- Core Structural & Configuration Tweaks -->
		<techLevel>Ultra</techLevel>
		<hidden>true</hidden>
		<permanentEnemy>true</permanentEnemy>
		<naturalEnemy>true</naturalEnemy>
		<canSiege>true</canSiege>
		<canStageAttacks>true</canStageAttacks>
		<rescueesCanJoin>true</rescueesCanJoin>
		<autoFlee>false</autoFlee>
		<permanentEnemyToEveryoneExcept>
			<li>TribeCivil</li>
		</permanentEnemyToEveryoneExcept>
		<arrivalLayerWhitelist>
			<li>Surface</li>
		</arrivalLayerWhitelist>
		<leaderTitle>Glorious Matriarch</leaderTitle>
		<fixedLeaderKinds>
			<li>Luxandra_Amazon_BloodMother</li>
		</fixedLeaderKinds>
		<leaderForceGenerateNewPawn>true</leaderForceGenerateNewPawn>
	
		<!-- Ideology setup -->
		<requiredMemes>
			<li MayRequire="Ludeon.RimWorld.Ideology">Supremacist</li>
			<li MayRequire="Ludeon.RimWorld.Ideology">Raider</li>
			<li MayRequire="rjw.sexperience.ideology">Rapist</li>
			<li MayRequire="Ludeon.RimWorld.Ideology">Cannibal</li>
			<li MayRequire="Ludeon.RimWorld.Ideology">Nudism</li>
			<li MayRequire="Ludeon.RimWorld.Ideology">FemaleSupremacy</li>
		</requiredMemes>
	
		<disallowedPrecepts>
			<li>Slavery_Classic</li>
			<li MayRequire="Ludeon.RimWorld.Ideology">Slavery_Disapproved</li>
			<li MayRequire="Ludeon.RimWorld.Ideology">Slavery_Horrible</li>
			<li MayRequire="Ludeon.RimWorld.Ideology">Slavery_Abhorrent</li>
			<li MayRequire="Ludeon.RimWorld.Ideology">Nudity_Female_CoveringAnythingButGroinDisapproved</li>
			<li MayRequire="Ludeon.RimWorld.Ideology">IdeoDiversity_Horrible</li>
			<li MayRequire="Ludeon.RimWorld.Ideology">Lovin_Prohibited</li>
			<li MayRequire="Ludeon.RimWorld.Ideology">Lovin_Horrible</li>
			<li MayRequire="Ludeon.RimWorld.Ideology">Lovin_SpouseOnly_Strict</li>
			<li MayRequire="Ludeon.RimWorld.Ideology">Lovin_SpouseOnly_Moderate</li>
			<li MayRequire="Ludeon.RimWorld.Ideology">Lovin_SpouseOnly_Mild</li>
      
			<li MayRequire="rjw.sexperience.ideology">Pregnancy_NoRules</li>
			<li MayRequire="rjw.sexperience.ideology">Pregnancy_Horrible</li>
			<li MayRequire="rjw.sexperience.ideology">GenitalSize_NoRules</li>
			<li MayRequire="rjw.sexperience.ideology">GenitalSize_Smaller_Better</li>
			<li MayRequire="rjw.sexperience.ideology">Incestuos_Free</li>
			<li MayRequire="rjw.sexperience.ideology">Incestuos_IncestOnly</li>
			<li MayRequire="rjw.sexperience.ideology">Bestiality_Abhorrent</li>
			<li MayRequire="rjw.sexperience.ideology">Bestiality_Horrible</li>
			<li MayRequire="rjw.sexperience.ideology">Bestiality_Disapproved</li>
			<li MayRequire="rjw.sexperience.ideology">Sex_Free</li>
			<li MayRequire="rjw.sexperience.ideology">Sex_AnalOnly</li>
			<li MayRequire="rjw.sexperience.ideology">Sex_OralOnly</li>
			<li MayRequire="rjw.sexperience.ideology">Sex_Promiscuous</li>
			<li MayRequire="rjw.sexperience.ideology">Virgin_PreciousF</li>
			<li MayRequire="rjw.sexperience.ideology">Virgin_PreciousM</li>
			<li MayRequire="rjw.sexperience.ideology">Virgin_OnlyForSpouseF</li>
			<li MayRequire="rjw.sexperience.ideology">Virgin_OnlyForSpouseM</li>
			<li MayRequire="rjw.sexperience.ideology">Virgin_UselessM</li>
			
			<li MayRequire="abscon.privacy.please">Exhibitionism_Disapproved</li>
			<li MayRequire="abscon.privacy.please">Exhibitionism_Acceptable</li>
			<li MayRequire="abscon.privacy.please">Infidelity_Heartbreaking</li>
			<li MayRequire="abscon.privacy.please">Infidelity_Disapproved</li>
		</disallowedPrecepts>
    
		<!-- World Customization -->
		<requiredCountAtGameStart>1</requiredCountAtGameStart>
		<maxConfigurableAtWorldCreation>1</maxConfigurableAtWorldCreation>
		<canMakeRandomly>false</canMakeRandomly>
		<listOrderPriority Inherit="False">70</listOrderPriority>
		<settlementGenerationWeight>0</settlementGenerationWeight>
    
		<!-- Aesthetics & Visual Attributes -->
