	<ThingDef ParentName="BuildingBase" Name="Luxandra_SacredMonumentBase" Abstract="True">
		<description>A grand monument dedicated to Luxandra. Can only be constructed while she guides your colony's fate.</description>
		<category>Building</category>
		<thingClass>Building</thingClass>
		<selectable>true</selectable>
		<rotatable>false</rotatable>
		<designationCategory>Misc</designationCategory>
		<uiOrder>3000</uiOrder>
		<drawerType>MapMeshAndRealTime</drawerType>
		<terrainAffordanceNeeded>Medium</terrainAffordanceNeeded>
		<leaveResourcesWhenKilled>true</leaveResourcesWhenKilled>
		<filthLeaving>Filth_RubbleRock</filthLeaving>
		<uiIconScale>0.8</uiIconScale>
		<uiIconOffset>(0, 0.04)</uiIconOffset>
    
		<stuffCategories>
			<li>Metallic</li>
			<li>Stony</li>
		</stuffCategories>
		<costList>
			<Luxandra_HeartOfLust>1</Luxandra_HeartOfLust>
		</costList>
	
		<thingCategories>
			<li>BuildingsMisc</li>
		</thingCategories>
		<minifiedDef>MinifiedThing</minifiedDef>
		<comps>
			<li Class="CompProperties_AffectedByFacilities">
				<linkableFacilities>
					<li>Luxandra_TributePedestal</li>
				</linkableFacilities>
			</li>
			<li Class="CompProperties_Glower">
				<glowRadius>10</glowRadius>
				<glowColor>(255, 182, 193, 0)</glowColor>
			</li>
			<li Class="LuxandraLust.CompProperties_LuxandraMonument"/>
			<li Class="CompProperties_MeditationFocus">
				<statDef>MeditationFocusStrength</statDef>
				<focusTypes>
					<li>Artistic</li>
					<li>Sex</li>
				</focusTypes>
			</li>
		</comps>
		<!-- <designatorDropdown>Luxandra_Altars</designatorDropdown> -->
	</ThingDef>

	<!-- ========================================== -->
	<!-- 1. THE 2x2 VERSION                         -->
	<!-- ========================================== -->
	<ThingDef ParentName="Luxandra_SacredMonumentBase">
		<defName>Luxandra_SacredMonument</defName>
		<label>Monument of Luxandra (Small)</label>
		<size>(2,2)</size>
		<costStuffCount>150</costStuffCount>
		<statBases>
			<MaxHitPoints>200</MaxHitPoints>
			<WorkToBuild>8000</WorkToBuild>
			<Beauty>50</Beauty>
			<MeditationFocusStrength>0.15</MeditationFocusStrength>
			<Mass>75</Mass>
		</statBases>
		<graphicData>
			<texPath>Things/Buildings/Luxandra_Altar</texPath>
			<graphicClass>Graphic_Single</graphicClass>
			<drawSize>(4,4)</drawSize>
		</graphicData>
	</ThingDef>

