<?xml version="1.0" encoding="utf-8" ?>
<!-- This is totally not nymphs. Nope. Totally not the nymphs from RJW 
	except they actually work (most of the time) -->
<Defs>


	<!-- Faction -->
	<FactionDef ParentName="FactionBase">
		<defName>Luxandra_DeviantHordeFaction</defName>
		<label>deviant horde</label>
		<description>A wild swarm of deviant humans.</description>
		<pawnSingular>Carnal deviant</pawnSingular>
		<pawnsPlural>Carnal deviants</pawnsPlural>
		<hidden>true</hidden>
		<permanentEnemy>true</permanentEnemy>
		<autoFlee>false</autoFlee>
		<canSiege>false</canSiege>
		<canStageAttacks>true</canStageAttacks>
		<canGenerateQuestSites>true</canGenerateQuestSites>
		<factionIconPath>World/WorldObjects/Expanding/CannibalTribe</factionIconPath>
		<techLevel>Neolithic</techLevel>
		<backstoryFilters>
			<li>
				<categories>
					<li>Luxandra_PrimalLustDeviant</li>
				</categories>
			</li>
		</backstoryFilters>
		<leaderTitle>Carnal Master</leaderTitle>
		<disallowedMemes>
			<li MayRequire="Ludeon.RimWorld.Ideology">Structure_Ideological</li>
			<li MayRequire="Ludeon.RimWorld.Ideology">Transhumanist</li>
			<li MayRequire="Ludeon.RimWorld.Ideology">Blindsight</li>
		</disallowedMemes>
		<disallowedPrecepts>
			<li MayRequire="Ludeon.RimWorld.Ideology">Nudity_Male_CoveringAnythingButGroinDisapproved</li>
			<li MayRequire="Ludeon.RimWorld.Ideology">Nudity_Female_CoveringAnythingButGroinDisapproved</li>
		</disallowedPrecepts>
		<requiredMemes>
			<li MayRequire="Ludeon.RimWorld.Ideology">Nudism</li>
			<li MayRequire="Ludeon.RimWorld.Ideology">Cannibal</li>
		</requiredMemes>
		<factionNameMaker>NamerFactionTribal</factionNameMaker>
		<settlementNameMaker>NamerSettlementTribal</settlementNameMaker>
		<requiredCountAtGameStart>1</requiredCountAtGameStart>
		<maxConfigurableAtWorldCreation>1</maxConfigurableAtWorldCreation>
		<configurationListOrderPriority>2000</configurationListOrderPriority>
		<displayInFactionSelection>false</displayInFactionSelection>
		<canSiege>false</canSiege>
		<raidCommonalityFromPointsCurve>
			<points>
				<li>(0, 0)</li>
				<li>(500, 0)</li>
				<li>(1500, 0.1)</li>
			</points>
		</raidCommonalityFromPointsCurve>
		<maxPawnCostPerTotalPointsCurve>
			<points>
				<li>(0, 35)</li>
				<li>(70, 50)</li>
				<li>(700, 100)</li>
				<li>(1300, 150)</li>
				<li>(100000, 10000)</li>
			</points>
		</maxPawnCostPerTotalPointsCurve>
		<pawnGroupMakers>
			<li>
				<kindDef>Combat</kindDef>
				<commonality>100</commonality>
				<options>
					<Luxandra_CarnalDeviantStriker>20</Luxandra_CarnalDeviantStriker>
					<Luxandra_CarnalAlphaLeader>3</Luxandra_CarnalAlphaLeader>
				</options>
			</li>

			<li>
				<kindDef>Peaceful</kindDef>
				<options>
					<Luxandra_CarnalDeviantStriker>20</Luxandra_CarnalDeviantStriker>
					<Luxandra_CarnalAlphaLeader>3</Luxandra_CarnalAlphaLeader>
				</options>
			</li>

			<li>
				<kindDef>Settlement</kindDef>
				<options>
					<Luxandra_CarnalDeviantStriker>20</Luxandra_CarnalDeviantStriker>
					<Luxandra_CarnalAlphaLeader>3</Luxandra_CarnalAlphaLeader>
				</options>
			</li>
		</pawnGroupMakers>
	</FactionDef>

	<!-- Actual pawn types -->
	<PawnKindDef>
		<defName>Luxandra_CarnalDeviantStriker</defName>
		<label>Carnal deviant</label>
		<race>Human</race>
		<combatPower>30</combatPower>
		<invNutrition>0</invNutrition>
		<itemQuality>Poor</itemQuality>
		<apparelMoney>0~0</apparelMoney>
		<weaponMoney>0~0</weaponMoney>
		<apparelAllowHeadgearChance>0</apparelAllowHeadgearChance>
		<apparelTags>
		</apparelTags>
		<techHediffsChance>0</techHediffsChance>
		<backstoryFiltersOverride>
			<li>
				<categories>
					<li>Luxandra_RaiderDeviantCategory</li>
				</categories>
			</li>
		</backstoryFiltersOverride>
		<forcedTraits>
			<li>
				<def>Nymphomaniac</def>
			</li>
			<li>
				<def>Rapist</def>
			</li>
			<li>
				<def>Bisexual</def>
			</li>
			<!-- This used to have Zoophile too but apparently they kept 
			raping animals ignoring colonists ooops -->
		</forcedTraits>
		<initialWillRange>5~20</initialWillRange>
		<initialResistanceRange>6~20</initialResistanceRange>
		<chronologicalAgeRange>20~30</chronologicalAgeRange>
		<defaultFactionType>Luxandra_DeviantHordeFaction</defaultFactionType>
	</PawnKindDef>
	
	<PawnKindDef>
		<defName>Luxandra_CarnalAlphaLeader</defName>
		<label>Carnal alpha</label>
		<race>Human</race>
		<combatPower>60</combatPower>
		<invNutrition>0</invNutrition>
		<itemQuality>Poor</itemQuality>
		<apparelMoney>0~0</apparelMoney>
		<weaponMoney>0~0</weaponMoney>
		<apparelAllowHeadgearChance>0</apparelAllowHeadgearChance>
		<apparelTags>
		</apparelTags>
		<techHediffsChance>0</techHediffsChance>
		<backstoryFiltersOverride>
			<li>
				<categories>
					<li>Luxandra_DeviantLeaderCategory</li>
				</categories>
			</li>
		</backstoryFiltersOverride>
		<forcedTraits>
			<li>
				<def>Nymphomaniac</def>
			</li>
			<li>
				<def>Rapist</def>
			</li>
			<li>
				<def>Bisexual</def>
			</li>
		</forcedTraits>
		<initialWillRange>1~2</initialWillRange>
		<initialResistanceRange>2~5</initialResistanceRange>
		<chronologicalAgeRange>18~35</chronologicalAgeRange>
		<defaultFactionType>Luxandra_DeviantHordeFaction</defaultFactionType>
	</PawnKindDef>

	<!-- DEBUFF APPLIED TO THE VICTIMS -->
	<HediffDef>
		<defName>Luxandra_DeviantStupor</defName>
		<label>lustful stupor</label>
		<description>A psychic fog clouding the mind. Builds up until the victim collapses into a helpless coma.</description>
		<hediffClass>HediffWithComps</hediffClass>
		<defaultLabelColor>(0.8, 0.4, 0.7)</defaultLabelColor>
		<maxSeverity>1.0</maxSeverity>
		<comps>
			<li Class="HediffCompProperties_SeverityPerDay">
				<severityPerDay>-0.5</severityPerDay>
			</li>
		</comps>
		<stages>
			<li>
				<label>hazed</label>
				<minSeverity>0.01</minSeverity>
				<capMods>
					<li>
						<capacity>Consciousness</capacity>
						<offset>-0.10</offset>
					</li>
				</capMods>
			</li>
			<li>
				<label>clouded</label>
				<minSeverity>0.40</minSeverity>
				<capMods>
					<li>
						<capacity>Consciousness</capacity>
						<offset>-0.30</offset>
					</li>
					<li>
						<capacity>Moving</capacity>
						<offset>-0.15</offset>
					</li>
				</capMods>
			</li>
			<li>
				<label>anesthetized stupor</label>
				<minSeverity>0.80</minSeverity>
				<capMods>
					<li>
						<capacity>Consciousness</capacity>
						<setMax>0.1</setMax>
					</li>
				</capMods>
			</li>
		</stages>
	</HediffDef>

	<!-- The "weapon" and all -->
	<ToolCapacityDef>
		<defName>Luxandra_StuporTouchCapacity</defName>
		<label>sedative touch</label>
	</ToolCapacityDef>

	<ManeuverDef>
		<defName>Luxandra_StuporTouchManeuver</defName>
		<requiredCapacity>Luxandra_StuporTouchCapacity</requiredCapacity>
		<verb>
			<verbClass>Verb_MeleeAttackDamage</verbClass>
		</verb>
		<logEntryDef>MeleeAttack</logEntryDef>
	</ManeuverDef>

	<HediffDef ParentName="ImplantHediffBase">
		<defName>Luxandra_EnthrallingTouch</defName>
		<label>sensual touch</label>
		<description>A poisonous touch evolved to weaken the preys, in order to use them while they're still alive. The warm poison also serves the secondary purpose of warming the Deviant's body, increasing cold resistance and pain tolerance.</description>
		<hediffClass>Hediff_Implant</hediffClass>
		<defaultLabelColor>(0.8, 0.4, 0.7)</defaultLabelColor>
		<isBad>false</isBad>
		<stages>
			<li>
				<painOffset>-0.30</painOffset>
				<painFactor>0.70</painFactor>
				<statFactors>
					<MeleeDamageFactor>0.05</MeleeDamageFactor>
				</statFactors>
				<statOffsets>
					<ComfyTemperatureMin>-20</ComfyTemperatureMin>
				</statOffsets>
			</li>
		</stages>
		<comps>
			<li Class="HediffCompProperties_VerbGiver">
				<tools>
					<li>
						<label>flesh stroke</label>
						<capacities>
							<li>Blunt</li>
						</capacities>
						<power>2</power>
						<cooldownTime>1.5</cooldownTime>
						<extraMeleeDamages>
							<li>
								<def>Luxandra_StuporTouchDamage</def>
								<amount>1</amount>
								<chance>1.0</chance>
							</li>
						</extraMeleeDamages>
					</li>
				</tools>
			</li>
		</comps>
	</HediffDef>

	<DamageDef ParentName="BluntBase">
		<defName>Luxandra_StuporTouchDamage</defName>
		<label>sedative contact</label>
		<additionalHediffs>
			<li>
				<hediff>Luxandra_DeviantStupor</hediff>
				<severityPerDamageDealt>0.1</severityPerDamageDealt>
				<victimSeverityScalingByInvBodySize>true</victimSeverityScalingByInvBodySize>
			</li>
		</additionalHediffs>
		<applyAdditionalHediffsIfHuntingForFood>false</applyAdditionalHediffsIfHuntingForFood>
	</DamageDef>
</Defs>