	<!-- Starvation Buff (keeps them fast even while completely starving) -->
	<HediffDef>
		<defName>Luxandra_PrimalFeralStarvation</defName>
		<label>feral desperation</label>
		<description>Adrenaline triggered by severe pack starvation. Relying only on animal impulse, this human is moving significantly faster than normal to secure their next meal.</description>
		<hediffClass>HediffWithComps</hediffClass>
		<defaultLabelColor>(0.9, 0.4, 0.1)</defaultLabelColor>
		<stages>
			<li>
				<statOffsets>
					<MoveSpeed>0.80</MoveSpeed>
					<MeleeDodgeChance>0.15</MeleeDodgeChance>
					<PainShockThreshold>-0.15</PainShockThreshold>
				</statOffsets>
				<capMods>
					<li>
						<capacity>Manipulation</capacity>
						<offset>-0.2</offset>
					</li>
				</capMods>
			</li>
		</stages>
		<comps>
			<li Class="HediffCompProperties_Disappears">
				<disappearsAfterTicks>45000</disappearsAfterTicks>
				<showRemainingTime>true</showRemainingTime>
			</li>
		</comps>
	</HediffDef>
</Defs>