<Defs>
  <IncidentDef>
    <defName>Luxandra_Inc_AmazonStealthAmbush</defName>
    <label>amazon stealth ambush</label>
    <workerClass>LuxandraLust.IncidentWorker_AmazonStealthAmbush</workerClass>
    <targetTags>
      <li>Map_PlayerHome</li>
    </targetTags>
    <pointsScaleable>true</pointsScaleable>
	<category>ThreatBig</category>
