<?xml version="1.0" encoding="utf-8" ?>
<Patch>
  <Operation Class="PatchOperationAdd">
    <!-- Targets the stock generators for non empire orbital and caravan exotic traders, and shaman merchants -->
    <xpath>/Defs/TraderKindDef[defName="Orbital_Exotic" or defName="Caravan_Outlander_Exotic" or defName="Caravan_Neolithic_Exotic" or defName="Caravan_Neolithic_ShamanMerchant]/stockGenerators</xpath>
    <value>
      <li Class="StockGenerator_SingleDef">
        <thingDef>Luxandra_HeartOfLust</thingDef>
        <countRange>1~1</countRange> <!-- Traders will bring 1 or 2 at a time -->
      </li>
    </value>
  </Operation>
</Patch>